        "jsonBody": "{\n  \"language\": \"en\",\n  \"locationQuery\": \"leeds\",\n  \"maxCrawledPlacesPerSearch\": 10,\n  \"searchStringsArray\": [\n    \"dentist\"\n  ],\n  \"skipClosedPlaces\": false,\n  \"placeMinimumStars\": \"\",\n  \"website\": \"allPlaces\",\n  \"searchMatching\": \"all\"\n}",
        "options": {
