      "id": "dee3f72e-dfa0-489b-b8c0-9e755fbe4b62",
      "name": "Scrape Google Maps"
    },
    {
      "parameters": {
        "jsCode": "// Input is your HTTP Request output\n// It looks like: [ { body: [ {...place}, {...place}, ... ], headers: {...}, ... } ]\n\nconst root = items[0].json;\nconst container = Array.isArray(root) ? root[0] : root;\nconst places = container.body || [];\n\n// Helper to strip empty fields\nconst stripEmpty = (obj) =>\n  Object.fromEntries(Object.entries(obj).filter(([_, v]) => v != null && v !== ''));\n\nconst cleaned = places.map(p => stripEmpty({\n  name: p.title || p.name || null,\n  address: p.address || null,\n  email: p.email || p.emailAddress || (p.emails?.[0] ?? null) || null,  // often not present in Maps\n  phone: p.phone || p.phoneNumber || null,\n  website: p.website || null,\n}));\n\n// Optionally also create a human-readable bullet list (handy for Slack/Email)\nconst summary = cleaned.map(b => {\n  return [\n    `- ${b.name ?? 'N/A'}`,\n    `- ${b.address ?? 'N/A'}`,\n    `- ${b.email ?? 'N/A'}`,\n    `- ${b.phone ?? 'N/A'}`,\n    b.website ? `- ${b.website}` : null,\n  ].filter(Boolean).join('\\n');\n}).join('\\n\\n');\n\n// Return two outputs:\n// 1) one item per business (structured fields)\n// 2) a single item with a `summary` string (nice for copy/paste)\nreturn [\n  ...cleaned.map(x => ({ json: x })),\n  { json: { summary } },\n];"
      },
