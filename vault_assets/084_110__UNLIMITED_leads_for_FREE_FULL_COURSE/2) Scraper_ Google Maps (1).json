    {
      "parameters": {
        "jsCode": "// --- Extract visible text from HTML ---\n// Input: HTML string in $json.data or $json.body (depending on your HTTP node)\nconst htmlRaw =\n  typeof $json?.data === 'string' ? $json.data :\n  typeof $json?.body === 'string' ? $json.body :\n  (typeof $json === 'string' ? $json : '');\n\nif (!htmlRaw) {\n  return [{ json: { text: '', note: 'no HTML detected in input' } }];\n}\n\n// 1. Remove <script>, <style>, and <noscript> blocks\nlet text = htmlRaw\n  .replace(/<script[\\s\\S]*?>[\\s\\S]*?<\\/script>/gi, '')\n  .replace(/<style[\\s\\S]*?>[\\s\\S]*?<\\/style>/gi, '')\n  .replace(/<noscript[\\s\\S]*?>[\\s\\S]*?<\\/noscript>/gi, '');\n\n// 2. Replace <br> and <p> with newlines for structure\ntext = text.replace(/<br\\s*\\/?>/gi, '\\n').replace(/<\\/p>/gi, '\\n');\n\n// 3. Strip remaining HTML tags\ntext = text.replace(/<[^>]+>/g, '');\n\n// 4. Decode common HTML entities (&amp; → &, etc.)\ntext = text\n  .replace(/&nbsp;/gi, ' ')\n  .replace(/&amp;/gi, '&')\n  .replace(/&lt;/gi, '<')\n  .replace(/&gt;/gi, '>')\n  .replace(/&quot;/gi, '\"')\n  .replace(/&#39;/gi, \"'\");\n\n// 5. Clean up whitespace and line breaks\ntext = text.replace(/\\s{2,}/g, ' ').replace(/\\n{2,}/g, '\\n').trim();\n\n// Return extracted text\nreturn [{ json: { text } }];\n"
      },
